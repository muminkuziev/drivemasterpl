# PostgreSQL ulanish satri
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/drivemaster?schema=public"

# @BotFather orqali olingan Telegram bot tokeni
BOT_TOKEN="123456:ABC-your-telegram-bot-token"

# Admin panelga kirish uchun maxfiy token (uzun tasodifiy satr qiling)
ADMIN_TOKEN="change-me-to-a-long-random-secret"

# Telegram admin foydalanuvchilari (vergul bilan ajratilgan Telegram user ID'lar)
ADMIN_TELEGRAM_IDS="123456789"

# Qo'lda BLIK to'lov qabul qilinadigan telefon raqami (Profile sahifasida ko'rsatiladi)
ADMIN_BLIK_PHONE=""

# Production'da media (video/rasm) papkasi kod bilan bir joyda bo'lmasa (masalan
# Render Persistent Disk), shu yerga uning yo'lini ko'rsating. Lokal devda bo'sh qoldiring.
MEDIA_ROOT=""

# Phase 2'da to'lov integratsiyasi uchun
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# WebApp (Telegram Mini App) manzili — Telegram HTTPS talab qiladi,
# localhost ishlamaydi. Test uchun ngrok yoki shunga o'xshash tunnel,
# productionda haqiqiy domen kerak. Bo'sh bo'lsa, botda WebApp tugmasi
# ko'rinmaydi (asosiy menyu buttonlar bilan ishlashda davom etadi).
WEBAPP_URL=""

# AI Tarjimon (ovozli tarjima) uchun OpenAI API kaliti. Bo'sh bo'lsa,
# tarjima so'rovlari xato qaytaradi.
OPENAI_API_KEY=""

# AI Tarjimonni butunlay o'chirish uchun favqulodda tugma (xarajat
# kutilmaganda oshib ketsa, kodni o'zgartirmasdan shu yerni "false" qiling).
TRANSLATOR_ENABLED="true"

# Bepul foydalanuvchi uchun umumiy (kunlik emas, hammasi bo'lib) tarjima
# limiti va premium foydalanuvchi uchun kunlik limit — API xarajatini
# nazorat qilish uchun.
TRANSLATOR_FREE_TOTAL_LIMIT="3"
TRANSLATOR_PREMIUM_DAILY_LIMIT="20"

# Mijoz bazasini yig'ish bosqichida barcha teoriya kontenti (matn/rasm/video)
# hamma uchun bepul ochiladi, premium tekshiruvi (shu jumladan qurilma-bog'lash)
# butunlay chetlab o'tiladi. Foydalanuvchilarning isPremium qiymati bazada
# o'zgarmaydi — shu yerni "false" qilib qaytarish yetarli, migratsiya kerak emas.
THEORY_FREE_FOR_ALL="true"
